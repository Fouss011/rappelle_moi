{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1",
        "EAS_BUILD_SKIP_LOCKFILE_CHECK": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EAS_NO_FROZEN_LOCKFILE": "1",
        "EAS_BUILD_SKIP_LOCKFILE_CHECK": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}